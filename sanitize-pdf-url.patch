+# Matches a bare http(s) URL and stops at the first character that can't be
+# part of one — whitespace, quotes, or Markdown/brackets like [text](url).
+# Models occasionally hand back a URL still wearing a stray '[', ']', '(',
+# ')', or trailing punctuation picked up from a Markdown link or sentence;
+# without this, requests just 404s on the mangled string.
+_URL_RE = re.compile(r"https?://[^\s\"'<>\[\]()]+")
+
+
+def _sanitize_pdf_url(raw_url: str) -> str:
+    match = _URL_RE.search(raw_url.strip())
+    if not match:
+        raise ValueError(f"'{raw_url}' does not look like a valid http(s) URL.")
+    url = match.group(0)
+    # Trailing sentence punctuation (periods, commas, etc.) is never valid at
+    # the end of an arXiv PDF URL, so trim it defensively too.
+    return url.rstrip(".,;:!?")
+
 
