# Force LF line endings regardless of OS — prevents Windows CRLF from breaking
# multi-line Dockerfile RUN commands during Linux-based builds (Render, HF, etc.)
* text=auto eol=lf

Dockerfile text eol=lf
*.sh text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf
